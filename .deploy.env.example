# Copy to .deploy.env and replace the example values.
# .deploy.env is ignored by Git and excluded from rsync deployments.
DEPLOY_HOST=203.0.113.10
DEPLOY_USER=ubuntu
SSH_KEY="$HOME/.ssh/id_ed25519"

# The bundled systemd units assume these defaults.
REMOTE_DIR=/opt/orsp-legado-adapter
REMOTE_OWNER=ubuntu
NODE_BIN_DIR=/opt/nodejs/bin
SITE_URL=https://book.openany.shop
