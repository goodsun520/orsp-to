# Application
PORT=8790
PUBLIC_ORIGIN=http://127.0.0.1:8790
DATA_DIR=./data/sources

# Cover proxy transport/cache (optional; defaults shown)
COVER_FETCH_TIMEOUT_MS=10000
COVER_UPSTREAM_CONNECTIONS=6
COVER_CACHE_DIR=./data/sources/.cover-cache
COVER_CACHE_FRESH_HOURS=24
COVER_CACHE_STALE_HOURS=168
COVER_CACHE_MAX_MB=256

# GitHub OAuth App. Callback URL: ${PUBLIC_ORIGIN}/api/admin/github/callback
# miloquinn is always allowed; add optional extra administrators as a comma-separated list.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_ADMIN_LOGINS=

# Optional local recovery login. Generate a strong value if enabled.
ADMIN_PASSWORD=

# Generate a strong, unique value for production. Do not commit real values.
STATS_HASH_KEY=
