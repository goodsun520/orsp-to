# Application
PORT=8790
PUBLIC_ORIGIN=http://127.0.0.1:8790
DATA_DIR=./data/sources

# Cover proxy transport/cache (optional; defaults shown)
COVER_FETCH_TIMEOUT_MS=10000
COVER_UPSTREAM_CONNECTIONS=6
COVER_CACHE_DIR=./data/sources/.cover-cache
COVER_CACHE_FRESH_HOURS=24
COVER_CACHE_STALE_HOURS=168
COVER_CACHE_MAX_MB=256

# Generate strong, unique values for production. Do not commit real values.
ADMIN_PASSWORD=
STATS_HASH_KEY=
